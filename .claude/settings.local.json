{
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebFetch(domain:langfuse.com)",
      "WebSearch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pip install langfuse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/metrics_hook.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/metrics_hook.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/langfuse_hook.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/metrics_hook.py"
          }
        ]
      }
    ]
  }
}
